# Environment variable template — copy this to .env and fill in your values
# cp .env.example .env

# Database (TimescaleDB via Docker)
DATABASE_URL=postgresql+asyncpg://sepsis_user:sepsis_pass_dev@127.0.0.1:5434/sepsis_watch
SYNC_DATABASE_URL=postgresql://sepsis_user:sepsis_pass_dev@127.0.0.1:5434/sepsis_watch

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM — priority: Groq → Anthropic → Ollama → rule-based fallback
# Groq (FREE, 14,400 req/day) — get key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Anthropic (paid, optional backup)
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Ollama (local only — leave blank on cloud deployments)
OLLAMA_MODEL=
OLLAMA_HOST=
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App
APP_ENV=development
SECRET_KEY=change_this_to_a_random_string_in_production
